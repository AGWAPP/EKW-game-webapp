            if(isGameOver) return;

            if (players[0].pos > players[1].pos) {
                statusEl.innerHTML = `🏆 <span class="text-blue-700">${players[0].name} (${players[0].icon})</span> এগিয়ে পূর্ব কলকাতা জলাভূমি রক্ষায়!`;
            } else if (players[1].pos > players[0].pos) {
                statusEl.innerHTML = `🏆 <span class="text-green-700">${players[1].name} (${players[1].icon})</span> এগিয়ে পূর্ব কলকাতা জলাভূমি রক্ষায়!`;
            } else if (players[0].pos > 0 && players[0].pos === players[1].pos) {
                statusEl.innerHTML = `🤝 দুজনেই সমান তালে জলাভূমি রক্ষা করছেন!`;
            } else {
                statusEl.innerHTML = `🌿 চলুন, জলাভূমি রক্ষার খেলা শুরু করি!`;
            }
        }

        function updateTurnUI() {
            if (isGameOver) return;
            
            let turnText = document.getElementById('turnIndicator');
            let turnIcon = document.getElementById('turnIcon');
            let rollBtn = document.getElementById('rollBtn');
            let diceDisplay = document.getElementById('diceDisplay');
            let diceOverlay = document.getElementById('diceOverlay');
            let currentPlayer = players[currentPlayerIndex];

            diceOverlay.classList.remove('dice-hidden');

            turnText.childNodes[2].nodeValue = ` ${currentPlayer.name}-এর চাল`;
            turnIcon.innerText = currentPlayer.icon;
            turnText.className = currentPlayerIndex === 0 ? "text-xl font-bold mb-1 text-blue-600 flex items-center gap-2" : "text-xl font-bold mb-1 text-green-600 flex items-center gap-2";

            if (gameMode === 1 && currentPlayerIndex === 1) {
                rollBtn.disabled = true; 
                diceDisplay.classList.add('cursor-not-allowed');
                rollBtn.innerText = 'কম্পিউটার ভাবছে...'; 
                setTimeout(rollDice, 1500);
            } else {
                rollBtn.disabled = false; 
                diceDisplay.classList.remove('cursor-not-allowed');
                rollBtn.innerText = 'ছক্কা ঘোরান';
            }
        }

        function showBoardMessage(text, type) {
            const overlay = document.getElementById('boardMessageOverlay');
            overlay.className = ''; 
            
            if(type === 'snake') overlay.classList.add('msg-snake');
            else if(type === 'ladder') overlay.classList.add('msg-ladder');
            else if(type === 'win') overlay.classList.add('msg-win');
            else overlay.classList.add('msg-normal');

            let icon = '';
            if(type === 'snake') icon = '⚠️ <br>';
            if(type === 'ladder') icon = '🌿 <br>';
            if(type === 'win') icon = '🏆 <br>';

            overlay.innerHTML = `${icon}${text}`;
            overlay.classList.add('show-message');

            if(messageTimeout) clearTimeout(messageTimeout);
            if(type !== 'win') {
                messageTimeout = setTimeout(() => { overlay.classList.remove('show-message'); }, 2500);
            }
        }

        function getSquareCoords(pos) {
            if (pos < 1) pos = 1; if (pos > 100) pos = 100;
            let zeroIndexed = pos - 1;
            let row = Math.floor(zeroIndexed / 10);
            let col = zeroIndexed % 10;
            if (row % 2 !== 0) col = 9 - col;
            return { x: col * cellSize + cellSize / 2, y: (9 - row) * cellSize + cellSize / 2 };
        }

        function drawBadge(x, y, text, bgColor, textColor) {
            ctx.font = 'bold 14px "Noto Sans Bengali", sans-serif';
            let textWidth = ctx.measureText(text).width;
            let w = textWidth + 20; let h = 24;

            ctx.fillStyle = bgColor;
            ctx.beginPath();
            if(ctx.roundRect) ctx.roundRect(x - w/2, y - h/2, w, h, 12);
            else ctx.rect(x - w/2, y - h/2, w, h); 
            ctx.fill();
            
            ctx.strokeStyle = '#fff'; ctx.lineWidth = 2; ctx.stroke();
            ctx.fillStyle = textColor; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
            ctx.fillText(text, x, y + 1); 
        }

        function drawDestinationIcons() {
            ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
            const drawIcon = (pos, iconText) => {
                let coords = getSquareCoords(pos);
                ctx.globalAlpha = 0.5; ctx.font = '36px Arial';
                ctx.fillText(iconText, coords.x, coords.y - 5);
                ctx.globalAlpha = 1.0;
            };
            for (let key in snakes) drawIcon(snakes[key].end, snakes[key].icon);
            for (let key in ladders) drawIcon(ladders[key].end, ladders[key].icon);
        }

        function drawBoard() {
            ctx.clearRect(0, 0, boardSize, boardSize);
            for (let i = 0; i < 100; i++) {
                let pos = i + 1;
                let row = Math.floor(i / 10); let col = i % 10;
                if (row % 2 !== 0) col = 9 - col;
                let x = col * cellSize; let y = (9 - row) * cellSize;
                
                if ((row + col) % 2 === 0) ctx.fillStyle = '#e0f2fe'; 
                else ctx.fillStyle = '#dcfce7'; 
                ctx.fillRect(x, y, cellSize, cellSize);
                ctx.strokeStyle = '#a7f3d0'; ctx.lineWidth = 1; ctx.strokeRect(x, y, cellSize, cellSize);
                
                ctx.fillStyle = '#4b5563'; ctx.font = 'bold 18px Arial'; ctx.textAlign = 'left';
                ctx.fillText(toBengaliNum(pos), x + 6, y + 22);
            }
            drawDestinationIcons(); drawConnections(); drawPlayers();
        }

        function drawConnections() {
            ctx.lineCap = 'round';
            for (let start in snakes) {
                let startCoords = getSquareCoords(parseInt(start)); let endCoords = getSquareCoords(snakes[start].end);
                let midX = (startCoords.x + endCoords.x) / 2; let midY = (startCoords.y + endCoords.y) / 2;
                let cpX = midX + 60; let cpY = midY - 60;

                ctx.beginPath(); ctx.moveTo(startCoords.x, startCoords.y); ctx.quadraticCurveTo(cpX, cpY, endCoords.x, endCoords.y);
                ctx.strokeStyle = '#7f1d1d'; ctx.lineWidth = 16; ctx.stroke();
                
                ctx.beginPath(); ctx.moveTo(startCoords.x, startCoords.y); ctx.quadraticCurveTo(cpX, cpY, endCoords.x, endCoords.y);
                ctx.strokeStyle = '#ef4444'; ctx.lineWidth = 6; ctx.stroke();

                let bx = 0.25*startCoords.x + 0.5*cpX + 0.25*endCoords.x; let by = 0.25*startCoords.y + 0.5*cpY + 0.25*endCoords.y;
                drawBadge(bx, by, '⚠️ ধ্বংস', '#b91c1c', '#ffffff');
            }

            for (let start in ladders) {
                let startCoords = getSquareCoords(parseInt(start)); let endCoords = getSquareCoords(ladders[start].end);
                
                ctx.beginPath(); ctx.moveTo(startCoords.x, startCoords.y); ctx.lineTo(endCoords.x, endCoords.y);
                ctx.strokeStyle = '#15803d'; ctx.lineWidth = 14; ctx.stroke();

                ctx.beginPath(); ctx.moveTo(startCoords.x, startCoords.y); ctx.lineTo(endCoords.x, endCoords.y);
                ctx.strokeStyle = '#4ade80'; ctx.lineWidth = 6; ctx.stroke();

                let midX = (startCoords.x + endCoords.x) / 2; let midY = (startCoords.y + endCoords.y) / 2;
                drawBadge(midX, midY, '🌿 রক্ষা', '#16a34a', '#ffffff');
            }
        }

        function drawPlayers() {
            players.forEach((player, index) => {
                if (player.pos > 0) {
                    let coords = getSquareCoords(player.pos);
                    let offsetX = index === 0 ? -15 : 15; let offsetY = index === 0 ? -10 : 10;
                    
                    ctx.font = '40px Arial'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                    ctx.shadowColor = "rgba(0, 0, 0, 0.5)"; ctx.shadowBlur = 6; ctx.shadowOffsetX = 2; ctx.shadowOffsetY = 2;
                    ctx.fillText(player.icon, coords.x + offsetX, coords.y + offsetY);
                    ctx.shadowBlur = 0; ctx.shadowOffsetX = 0; ctx.shadowOffsetY = 0;
                }
            });
        }

        function handleDiceClick() {
            if (isGameOver || isMoving) return;
            if (gameMode === 1 && currentPlayerIndex === 1) return; 
            rollDice();
        }

        function rollDice() {
            if (isGameOver || isMoving) return;
            isMoving = true;
            document.getElementById('rollBtn').disabled = true;
            document.getElementById('diceDisplay').classList.add('cursor-not-allowed');

            playDiceSound(); // Play dice rattle sound

            const diceDisplay = document.getElementById('diceDisplay');
            diceDisplay.style.transform = 'scale(1.3) rotate(20deg)';
            
            const diceFaces = ['⚀', '⚁', '⚂', '⚃', '⚄', '⚅'];
            let shuffleCount = 0;
            
            let shuffleInterval = setInterval(() => {
                diceDisplay.innerText = diceFaces[Math.floor(Math.random() * 6)];
                shuffleCount++;
                if(shuffleCount > 8) {
                    clearInterval(shuffleInterval);
                    const roll = Math.floor(Math.random() * 6) + 1;
                    diceDisplay.innerText = diceFaces[roll - 1];
                    diceDisplay.style.transform = 'scale(1) rotate(0deg)';
                    
                    let player = players[currentPlayerIndex];
                    
                    setTimeout(() => {
                        document.getElementById('diceOverlay').classList.add('dice-hidden');
                        movePlayerStepByStep(player, roll);
                    }, 500);
                }
            }, 60);
        }

        function movePlayerStepByStep(player, totalSteps) {
            let stepsTaken = 0;
            let countingBox = document.getElementById('countingDisplay');
            
            if (player.pos + totalSteps > 100) {
                showBoardMessage(`১০০ ঘরে পৌঁছাতে ঠিক সংখ্যা প্রয়োজন।`, 'normal');
                setTimeout(() => { finishTurn(player); }, 2500);
                return;
            }

            countingBox.style.opacity = '1';
            countingBox.innerText = "গুনে গুনে এগোচ্ছে: ";
            
            let moveInterval = setInterval(() => {
                stepsTaken++; player.pos++;
                
                // Voice counting (Ek, Dui, Tin...)
                speakNumber(stepsTaken);
                
                countingBox.innerText += toBengaliNum(stepsTaken) + (stepsTaken < totalSteps ? " - " : "");
                drawBoard();

                if (stepsTaken >= totalSteps || player.pos === 100) {
                    clearInterval(moveInterval);
                    setTimeout(() => {
                        countingBox.style.opacity = '0'; 
                        checkSnakesLadders(player);
                    }, 600);
                }
            }, 700); // 700ms gap gives time for the voice to say the number
        }

        function checkSnakesLadders(player) {
            if (snakes[player.pos]) {
                playSnakeSound(); // Snake hit sound
                showBoardMessage(snakes[player.pos].msg, 'snake');
                player.pos = snakes[player.pos].end;
                drawBoard();
                setTimeout(() => { finishTurn(player); }, 2800); 

            } else if (ladders[player.pos]) {
                playLadderSound(); // Ladder hit sound
                showBoardMessage(ladders[player.pos].msg, 'ladder');
                player.pos = ladders[player.pos].end;
                drawBoard();
                setTimeout(() => { finishTurn(player); }, 2800); 
            } else {
                finishTurn(player);
            }
        }

        function finishTurn(player) {
            updateLeaderboard(); 

            if (player.pos === 100) {
                playWinSound(); // Winning music
                showBoardMessage(`অভিনন্দন! ${player.name} জলাভূমি রক্ষা করেছেন!`, 'win');
                document.getElementById('leaderboardStatus').innerHTML = `🎉 <b>${player.name} খেলায় বিজয়ী হয়েছেন!</b>`;
                isGameOver = true;
                document.getElementById('diceOverlay').classList.add('dice-hidden');
                return;
            }

            currentPlayerIndex = currentPlayerIndex === 0 ? 1 : 0;
            isMoving = false;
            updateTurnUI();
        }

        resetApp();

    </script>
</body>
</html>


