            setTimeout(() => playTone(200, 'sawtooth', 0.8), 500);
        }

        function playLadderSound() {
            initAudio();
            playTone(400, 'sine', 0.2);
            setTimeout(() => playTone(500, 'sine', 0.2), 150);
            setTimeout(() => playTone(600, 'sine', 0.4), 300);
            setTimeout(() => playTone(800, 'sine', 0.6), 450);
        }

