                } else {
                    players[1].icon = icon; players[1].name = 'খেলোয়াড় ২';
                    startGame();
                }
            }
        }

        function startGame() {
            document.getElementById('startModal').style.display = 'none';
            players[0].pos = 0; players[1].pos = 0;
            currentPlayerIndex = 0; isGameOver = false; isMoving = false;

