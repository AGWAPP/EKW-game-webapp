        };

        const snakes = {
            98: { end: 28, msg: 'অবৈধ দখল!', type: 'destroy', fact: "জলাভূমি ভরাট শহরে বিপদ ডেকে আনছে।" },
            85: { end: 53, msg: 'প্লাস্টিক দূষণ!', type: 'destroy', fact: "বর্জ্যে জল দূষিত হচ্ছে।" },
            62: { end: 18, msg: 'গাছ কাটা!', type: 'destroy', fact: "প্রাণীদের আবাসস্থল নষ্ট হচ্ছে।" },
            47: { end: 15, msg: 'অতিরিক্ত মাছ ধরা!', type: 'destroy', fact: "বাস্তুতন্ত্রের ভারসাম্য নষ্ট হচ্ছে।" },
            32: { end: 10, msg: 'অসচেতনতা!', type: 'destroy', fact: "মানুষ যত্রতত্র ময়লা ফেলছে।" }
        };

        const ekwGoals = {
            20: { title: "লক্ষ্য ১: জল পরিষ্কার", icon: "💧", text: "প্রাকৃতিকভাবে নর্দমার জল পরিশোধন করে দূষণ কমায়।" },
            40: { title: "লক্ষ্য ২: খাদ্য উৎপাদন", icon: "🐟", text: "মাছ ও শাকসবজি চাষ মানুষের খাদ্যের যোগান দেয়।" },
            60: { title: "লক্ষ্য ৩: বন্যা নিয়ন্ত্রণ", icon: "☔", text: "অতিরিক্ত বৃষ্টির জল ধরে রেখে শহরের বন্যা কমায়।" },
            80: { title: "লক্ষ্য ৪: জীববৈচিত্র্য", icon: "🦆", text: "বহু প্রজাতির মাছ, পাখি ও জলজ উদ্ভিদের আশ্রয়স্থল।" }
        };

        const roles = [
            { icon: '👨‍🔬', name: 'বিজ্ঞানী' },
            { icon: '👩‍🌾', name: 'কৃষক' },
            { icon: '🧒', name: 'স্বেচ্ছাসেবী' },
            { icon: '🧑‍🚒', name: 'বনরক্ষী' },
            { icon: '🧑‍🎓', name: 'ছাত্র' },
            { icon: '🐦', name: 'আলোকচিত্রী' }
        ];

        let players = [
            { id: 1, pos: 0, icon: '👨‍🔬', name: 'খেলোয়াড় ১', x: 0, y: GAME_SIZE, targetX: 0, targetY: GAME_SIZE, goalsShowed: [] },
            { id: 2, pos: 0, icon: '🤖', name: 'কম্পিউটার', x: 0, y: GAME_SIZE, targetX: 0, targetY: GAME_SIZE, goalsShowed: [] }
        ];

        // --- AUDIO SYSTEM ---
        let actx;
        function initAudio() {
            try {
                if (!actx) actx = new (window.AudioContext || window.webkitAudioContext)();
                if (actx.state === 'suspended') actx.resume();
            } catch(e) {}
        }

        function playTone(freq, type, duration, vol = 0.1, slideFreq = null) {
            try {
                if (!actx) return;
                const osc = actx.createOscillator();
                const gain = actx.createGain();
                osc.type = type;
                osc.connect(gain);
                gain.connect(actx.destination);
               
                osc.frequency.setValueAtTime(freq, actx.currentTime);
                if (slideFreq) osc.frequency.exponentialRampToValueAtTime(slideFreq, actx.currentTime + duration);
                gain.gain.setValueAtTime(vol, actx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, actx.currentTime + duration);
               
                osc.start(); osc.stop(actx.currentTime + duration);
            } catch(e) {}
        }

        const SFX = {
            step: () => playTone(300, 'sine', 0.1, 0.1),
            roll: () => { for(let i=0; i<6; i++) setTimeout(()=>playTone(600+Math.random()*400, 'triangle', 0.05, 0.1), i*80) },
            climb: () => { playTone(400, 'sine', 0.2, 0.1, 800); setTimeout(()=>playTone(600, 'sine', 0.4, 0.1, 1200), 200); },
            fall: () => { playTone(300, 'sawtooth', 0.4, 0.1, 100); document.body.classList.add('shake-screen'); setTimeout(()=>document.body.classList.remove('shake-screen'),500); },
            goal: () => { playTone(440, 'sine', 0.1, 0.1); setTimeout(()=>playTone(554, 'sine', 0.1, 0.1), 100); setTimeout(()=>playTone(659, 'sine', 0.3, 0.1), 200); },
            win: () => { playTone(523.25, 'sine', 0.2, 0.2); setTimeout(()=>playTone(659.25, 'sine', 0.2, 0.2), 200); setTimeout(()=>playTone(783.99, 'sine', 0.4, 0.2, 1046.50), 400); }
        };

        // --- UI & ROLE SELECTION ---
        function goToStep2(mode) {
            initAudio(); gameMode = mode;
            document.getElementById('step1').classList.add('hidden');
            document.getElementById('step2').classList.remove('hidden');
            selectingPlayer = 1; renderRoleGrid();
        }

        function renderRoleGrid() {
            let iconGrid = document.getElementById('iconGrid');
            iconGrid.innerHTML = '';
            roles.forEach((role, index) => {
                let isPicked = (selectingPlayer === 2 && players[0].icon === role.icon);
                iconGrid.innerHTML += `
                    <div onclick="if(!${isPicked}) selectRole(${index})"
                         class="icon-btn flex items-center gap-2 bg-gray-50 p-2 rounded-xl border-2 border-gray-200 hover:bg-green-50 ${isPicked ? 'opacity-50 pointer-events-none' : ''}">
                        <span class="text-2xl">${role.icon}</span>
                        <span class="font-bold text-xs text-gray-700">${role.name}</span>
                    </div>`;
            });
        }

        function selectRole(roleIndex) {
            initAudio(); let role = roles[roleIndex];
            if (gameMode === 1) {
                players[0].icon = role.icon; players[0].name = role.name;
                players[1].icon = '🤖'; players[1].name = 'কম্পিউটার';
                showIntroModal();
            } else {
                if (selectingPlayer === 1) {
                    players[0].icon = role.icon; players[0].name = role.name + ' (১)';
                    selectingPlayer = 2;
                    let title = document.getElementById('iconSelectionTitle');
                    title.innerText = '২য় খেলোয়াড়: ভূমিকা বেছে নিন';
                    title.className = "text-base font-bold text-red-800 mb-2 bg-red-100 p-2 rounded-lg";
                    renderRoleGrid();
                } else {
                    players[1].icon = role.icon; players[1].name = role.name + ' (২)';
                    showIntroModal();
                }
            }
        }

        function showIntroModal() {
            document.getElementById('startModal').style.display = 'none';
            let intro = document.getElementById('introModal');
            intro.classList.remove('hidden');
            intro.classList.add('flex');
        }

        function startGame() {
            document.getElementById('introModal').classList.add('hidden');
            document.getElementById('introModal').classList.remove('flex');
           
            document.getElementById('p1Icon').innerText = players[0].icon;
            document.getElementById('p1Name').innerText = players[0].name;
            document.getElementById('p2Icon').innerText = players[1].icon;
            document.getElementById('p2Name').innerText = players[1].name;
            updateUI(); gameLoop();
        }

        function getCellPos(cell) {
            if(cell === 0) return { x: 0, y: GAME_SIZE };
            let row = Math.floor((cell - 1) / 10);
            let col = (cell - 1) % 10;
            if (row % 2 !== 0) col = 9 - col;
            return { x: col * TILE + TILE / 2, y: GAME_SIZE - (row * TILE + TILE / 2) };
        }

        // --- DRAWING ---
        function drawBoard() {
            ctx.clearRect(0, 0, GAME_SIZE, GAME_SIZE);
            for(let i = 1; i <= 100; i++) {
                let row = Math.floor((i - 1) / 10); let col = (i - 1) % 10;
                let isAlt = (row + col) % 2 === 0;
                ctx.fillStyle = isAlt ? '#dcfce7' : '#f0fdf4';
                if([20,40,60,80].includes(i)) ctx.fillStyle = '#fef08a';
                if(i === 100) ctx.fillStyle = '#bfdbfe';

                let pos = getCellPos(i);
                ctx.fillRect(pos.x - TILE/2, pos.y - TILE/2, TILE, TILE);
                ctx.strokeStyle = '#bbf7d0'; ctx.lineWidth = 2;
                ctx.strokeRect(pos.x - TILE/2, pos.y - TILE/2, TILE, TILE);
               
                ctx.fillStyle = '#166534'; ctx.font = 'bold 24px "Noto Sans Bengali", sans-serif';
                ctx.textAlign = 'left'; ctx.textBaseline = 'top';
                ctx.fillText(toBnNum(i), pos.x - TILE/2 + 8, pos.y - TILE/2 + 8);
            }

            ctx.lineWidth = 6; ctx.lineCap = 'round';
            for(let start in snakes) drawConnection(parseInt(start), snakes[start].end, 'snake');
            for(let start in ladders) drawConnection(parseInt(start), ladders[start].end, 'ladder');

            players.forEach(p => {
                if(p.pos > 0) {
                    ctx.fillStyle = 'rgba(0,0,0,0.3)'; ctx.beginPath();
                    ctx.ellipse(p.x, p.y + 18, 20, 6, 0, 0, Math.PI * 2); ctx.fill();
                   
                    ctx.fillStyle = '#ffffff'; ctx.beginPath();
                    ctx.arc(p.x, p.y, 22, 0, Math.PI * 2); ctx.fill();
                   
                    ctx.lineWidth = 3; ctx.strokeStyle = p.id === 1 ? '#3b82f6' : '#ef4444'; ctx.stroke();
                    ctx.font = '28px sans-serif'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                    ctx.fillStyle = '#000000'; ctx.fillText(p.icon, p.x, p.y + 2);
                }
            });
        }

        function drawConnection(start, end, type) {
            let sPos = getCellPos(start); let ePos = getCellPos(end);
            if(type === 'snake') {
                ctx.strokeStyle = '#ef4444'; ctx.setLineDash([10, 10]);
                ctx.beginPath(); ctx.moveTo(sPos.x, sPos.y);
                ctx.quadraticCurveTo(sPos.x + 50, (sPos.y + ePos.y)/2, ePos.x, ePos.y);
                ctx.stroke();
                ctx.fillStyle = '#ef4444'; ctx.font = '30px sans-serif';
                ctx.fillText('⚠️', sPos.x, sPos.y - 10);
            } else {
                ctx.strokeStyle = '#22c55e'; ctx.setLineDash([]);
                ctx.beginPath(); ctx.moveTo(sPos.x, sPos.y); ctx.lineTo(ePos.x, ePos.y);
                ctx.stroke();
                ctx.fillStyle = '#22c55e'; ctx.font = '30px sans-serif';
                ctx.fillText('🌿', sPos.x, sPos.y + 10);
            }
            ctx.setLineDash([]);
        }

        // --- GAME LOGIC ---
        function updateUI() {
            let p1 = players[0]; let p2 = players[1];
            document.getElementById('p1Index').innerText = toBnNum(p1.pos) + '%';
            document.getElementById('p1Meter').style.width = p1.pos + '%';
            document.getElementById('p2Index').innerText = toBnNum(p2.pos) + '%';
            document.getElementById('p2Meter').style.width = p2.pos + '%';

            [20, 40, 60, 80, 100].forEach(val => {
                let b1 = document.getElementById('p1_badge_' + val);
                if(b1) { if(p1.pos >= val) b1.classList.add('active'); else b1.classList.remove('active'); }
                let b2 = document.getElementById('p2_badge_' + val);
                if(b2) { if(p2.pos >= val) b2.classList.add('active'); else b2.classList.remove('active'); }
            });

            document.getElementById('p1Card').classList.toggle('active-turn', currentPlayerIndex === 0);
            document.getElementById('p2Card').classList.toggle('active-turn', currentPlayerIndex === 1);

            let cp = players[currentPlayerIndex];
            document.getElementById('turnAvatar').innerText = cp.icon;
            let tn = document.getElementById('turnName');
            if(tn) tn.innerText = cp.name;

            let scene = document.getElementById('diceScene');
            if(gameMode === 1 && currentPlayerIndex === 1) {
                scene.classList.remove('dice-glow');
                scene.style.pointerEvents = 'none';
                scene.style.opacity = '0.7';
            } else {
                scene.classList.add('dice-glow');
                scene.style.pointerEvents = 'auto';
                scene.style.opacity = '1';
            }
        }

        function handleDiceClick() {
            if(isMoving || isGameOver) return;
            if(gameMode === 1 && currentPlayerIndex === 1) return;
            initAudio(); rollDice();
        }

        function rollDice() {
            isMoving = true; let p = players[currentPlayerIndex]; SFX.roll();
           
            document.getElementById('diceScene').classList.remove('dice-glow');
           
            let steps = Math.floor(Math.random() * 6) + 1;
            let cube = document.getElementById('diceCube');
            let rots = ['rotateY(0deg)', 'rotateX(-90deg)', 'rotateY(-90deg)', 'rotateY(90deg)', 'rotateX(90deg)', 'rotateY(180deg)'];
           
            cube.style.transform = `rotateX(${Math.random()*1440 + 720}deg) rotateY(${Math.random()*1440 + 720}deg)`;
           
            setTimeout(() => {
                cube.style.transform = `translateZ(-30px) ${rots[steps-1]}`;
                let disp = document.getElementById('countingDisplay');
                disp.innerText = toBnNum(steps);
                disp.style.opacity = 1;
               
                setTimeout(() => {
                    disp.style.opacity = 0;
                    movePlayer(p, steps);
                }, 800);
            }, 1200);
        }

        function movePlayer(player, steps) {
            let startPos = player.pos;
           
            // Exact roll logic for 100
            if(startPos + steps > 100) {
                let disp = document.getElementById('countingDisplay');
                disp.innerText = "সঠিক সংখ্যা চাই!";
                disp.classList.remove('text-green-600');
                disp.classList.add('text-red-500');
                disp.style.opacity = 1;
               
                setTimeout(() => {
                    disp.style.opacity = 0;
                    disp.classList.add('text-green-600');
                    disp.classList.remove('text-red-500');
                    endTurn();
                }, 1200);
                return;
            }

            let currentStep = 0;
            let intv = setInterval(() => {
                currentStep++; player.pos++;
                let t = getCellPos(player.pos);
                player.targetX = t.x; player.targetY = t.y;
                SFX.step(); updateUI();
                if(currentStep >= steps) {
                    clearInterval(intv); setTimeout(() => checkTileEffect(player), 300);
                }
            }, 250);
        }

        function checkTileEffect(player) {
            let pos = player.pos; let effect = snakes[pos] || ladders[pos];
            if(effect) {
                showKnowledgeCard(effect.msg, effect.fact, effect.type, () => {
                    player.pos = effect.end;
                    let t = getCellPos(effect.end);
                    player.targetX = t.x; player.targetY = t.y;
                   
                    if(effect.type === 'destroy') {
                        SFX.fall();
                        player.goalsShowed = player.goalsShowed.filter(m => m <= player.pos);
                    } else SFX.climb();
                   
                    updateUI(); setTimeout(() => checkMilestone(player), 800);
                });
            } else checkMilestone(player);
        }

        function checkMilestone(player) {
            let ms = [20, 40, 60, 80]; let achieved = [];
            for(let m of ms) {
                if(player.pos >= m && !player.goalsShowed.includes(m)) {
                    player.goalsShowed.push(m); achieved.push(ekwGoals[m]);
                }
            }
            if(achieved.length > 0) showMilestoneCard(achieved, player, () => checkWinCondition(player));
            else checkWinCondition(player);
        }

        function showMilestoneCard(goals, player, callback) {
            let card = document.getElementById('milestoneModal');
            document.getElementById('milestonePlayerName').innerHTML = `<span class="text-2xl">${player.icon}</span> ${player.name}`;
           
            document.getElementById('milestoneList').innerHTML = goals.map(g => `
                <div class="bg-white p-3 rounded-xl shadow-sm border-l-4 border-yellow-400 flex gap-3 items-start">
                    <div class="text-3xl">${g.icon}</div>
                    <div><h4 class="font-bold text-green-800 text-sm">${g.title}</h4><p class="text-xs text-gray-600 mt-1">${g.text}</p></div>
                </div>
            `).join('');

            SFX.goal(); card.classList.remove('hidden');
            window.currentMilestoneCallback = () => { card.classList.add('hidden'); callback(); };
        }
        function closeMilestoneCard() {
            if(window.currentMilestoneCallback) { window.currentMilestoneCallback(); window.currentMilestoneCallback = null; }
        }

        function showKnowledgeCard(msg, fact, type, callback) {
            let card = document.getElementById('knowledgeCard');
            let box = document.getElementById('kcBox'); let title = document.getElementById('kcTitle');
           
            box.classList.remove('border-red-500', 'border-green-500');
            document.getElementById('knowledgeText').innerHTML = `<strong class="text-base text-gray-800">${msg}</strong><br><br><span class="text-xs text-gray-600">${fact}</span>`;
           
            if(type === 'destroy') {
                box.classList.add('border-red-500');
                document.getElementById('kcBgIcon').innerText = '⚠️';
                title.innerHTML = '<span class="text-red-500">⚠️</span> সূচক পতন!';
                title.className = "text-lg font-black text-red-600 mb-2 flex items-center justify-center gap-2";
                document.getElementById('pollutionOverlay').style.opacity = '1';
                setTimeout(()=>document.getElementById('pollutionOverlay').style.opacity = '0', 1000);
            } else {
                box.classList.add('border-green-500');
                document.getElementById('kcBgIcon').innerText = '🌿';
                title.innerHTML = '<span class="text-green-500">🌿</span> দারুণ কাজ!';
                title.className = "text-lg font-black text-green-600 mb-2 flex items-center justify-center gap-2";
            }
           
            card.classList.remove('hidden');
            window.currentCardCallback = () => { card.classList.add('hidden'); callback(); };
        }
        function closeKnowledgeCard() {
            if(window.currentCardCallback) { window.currentCardCallback(); window.currentCardCallback = null; }
        }

        function checkWinCondition(player) {
            if(player.pos === 100) {
                isGameOver = true; SFX.win();
                let end = document.getElementById('cinematicEnd');
                end.classList.remove('hidden');
                end.classList.add('flex');
                setTimeout(() => {
                    end.classList.remove('opacity-0');
                    end.classList.add('opacity-100');
                }, 100);
                document.getElementById('winnerIcon').innerText = player.icon;
                document.getElementById('winnerName').innerText = player.name;
            } else endTurn();
        }

        function endTurn() {
            currentPlayerIndex = (currentPlayerIndex + 1) % players.length;
            updateUI(); isMoving = false;
            if(gameMode === 1 && currentPlayerIndex === 1 && !isGameOver) setTimeout(() => rollDice(), 1200);
        }

        function gameLoop() {
            players.forEach(p => {
                p.x += (p.targetX - p.x) * 0.15; p.y += (p.targetY - p.y) * 0.15;
            });
            drawBoard(); requestAnimationFrame(gameLoop);
        }
        drawBoard();
    </script>
</body>
